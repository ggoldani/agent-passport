    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@stellar/stellar-sdk": "^15.0.1",
    "@x402/core": "^2.9.0",
    "@x402/express": "^2.9.0",
    "@x402/stellar": "^2.9.0",
    "better-sqlite3": "^12.9.0",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "hono": "^4.12.12"
