  "version": "0.1.0",
  "scripts": {
    "contracts": "cargo test --manifest-path contracts/agent-passport/Cargo.toml",
    "worker": "tsx scripts/worker/index.ts",
    "provider": "tsx src/provider/server.ts",
    "dashboard": "npm --prefix web run dev",
