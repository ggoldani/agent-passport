# AgentPassport — pre-configured demo values (Stellar testnet)
# Copy this to .env for the hackathon demo: cp .env.demo .env
# Then fill in your own secret keys below.

# Stellar testnet / Soroban
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
STELLAR_RPC_URL="https://soroban-testnet.stellar.org"
STELLAR_HORIZON_URL="https://horizon-testnet.stellar.org"

# AgentPassport contract (already deployed on testnet)
CONTRACT_ID="CCIK4FM4PM7SXYFPBBTG5NCMH5TWCKHHK75RZSKUU5GA27UVLS572U7F"

# CLI signer — your funded testnet account secret key
AGENT_SECRET_KEY="SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# x402 facilitator
X402_FACILITATOR_URL="https://www.x402.org/facilitator"

# Demo provider address (receives x402 payments)
X402_PAY_TO="GC7TRXR2SJ7644453S5BR755L5M2OSUFIFOEAYGEPMUOKLPFI6HEKOPT"

# Provider runtime config
PROVIDER_PORT="3001"
PROVIDER_URL="http://localhost:3001"
PROVIDER_PRICE_XLM="1"

# Local StellarIntel companion service
STELLAR_MCP_URL="http://localhost:3005"

# --- ACCOUNTS (Stellar testnet — no real funds) ---
# RELAYER: authorized on-chain to register interactions.
# PROVIDER_OWNER: owns the demo provider address (X402_PAY_TO).

RELAYER_SECRET_KEY="SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
PROVIDER_OWNER_SECRET_KEY="SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
